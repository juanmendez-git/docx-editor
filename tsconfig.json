{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./packages/react/src/*"],
      "@juanmendez90/docx-js-editor": ["./packages/react/src/index.ts"],
      "@juanmendez90/docx-core": ["./packages/core/src/core.ts"],
      "@juanmendez90/docx-core/headless": ["./packages/core/src/headless.ts"],
      "@juanmendez90/docx-core/core-plugins": ["./packages/core/src/core-plugins/index.ts"],
      "@juanmendez90/docx-core/mcp": ["./packages/core/src/mcp/index.ts"],
      "@juanmendez90/docx-core/*": ["./packages/core/src/*"]
    }
  },
  "include": [
    "src",
    "packages/core/src",
    "packages/react/src",
    "examples/shared",
    "examples/vite",
    "examples/plugins"
  ],
  "exclude": ["node_modules", "dist", "examples/nextjs", "examples/remix", "examples/astro"]
}
